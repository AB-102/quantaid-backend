# Required
FLASK_SECRET_KEY=your-flask-secret-key
OPENAI_API_KEY=your-openai-api-key
MONGODB_URI=your-mongodb-connection-uri
FIRST_TIME_USER_EMAIL=your-dev-forced-onboarding@email.com
ADMIN_EMAILS=admin1@email.com,admin2@email.com

# Email (Resend) — used for password reset emails
RESEND_API_KEY=re_...your-resend-api-key
FROM_EMAIL=onboarding@resend.dev

# Session & CORS (optional — sensible defaults if omitted)
# SESSION_LIFETIME_MINUTES=10080
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# FRONTEND_URL=http://localhost:5173
