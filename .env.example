# Required
FLASK_SECRET_KEY=your-flask-secret-key
OPENAI_API_KEY=your-openai-api-key
MONGODB_URI=your-mongodb-connection-uri
MONGODB_URI_TEST=your-test-mongodb-connection-uri
ADMIN_EMAILS=admin1@email.com,admin2@email.com

# Email (Resend) — used for password reset emails
RESEND_API_KEY=re_...your-resend-api-key
FROM_EMAIL=onboarding@resend.dev # Onboarding only sends to the email registered with the above resend key, change after domain setup

# Dev forced onboarding (optional — set to an email to force onboarding for that email)
# FIRST_TIME_USER_EMAIL=your-dev-forced-onboarding@email.com

# Redis (optional — falls back to in-memory if omitted, set for Docker/production)
# REDIS_URL=redis://localhost:6379/0

# Session & CORS (optional — sensible defaults if omitted)
# FLASK_ENV=development # Change to "production" and set secure cookies and other settings
# SESSION_LIFETIME_MINUTES=10080
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# FRONTEND_URL=http://localhost:5173

# Rice University OIDC (optional — enables Rice SSO when set, disabled if omitted)
# Contact Rice OIT (helpdesk@rice.edu) for app registration and credentials.
# RICE_OIDC_CLIENT_ID=your-rice-oidc-client-id
# RICE_OIDC_CLIENT_SECRET=your-rice-oidc-client-secret
# RICE_OIDC_REDIRECT_URI=http://localhost:5000/auth/rice/callback

# Auth method feature flags (optional — all default to "true")
# Set to "false" to disable a login method for a specific deployment.
# quantaid.rice.edu: ENABLE_GOOGLE_SSO=false, ENABLE_EMAIL_PASSWORD_AUTH=false
# quantaid.org:      ENABLE_GOOGLE_SSO=true,  ENABLE_EMAIL_PASSWORD_AUTH=false
# ENABLE_GOOGLE_SSO=true
# ENABLE_EMAIL_PASSWORD_AUTH=true
